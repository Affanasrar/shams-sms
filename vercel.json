{
  "crons": [
    {
      "path": "/api/cron/fees",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/fees-reminder",
      "schedule": "0 6 * * *"
    }
  ]
  ,"headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}